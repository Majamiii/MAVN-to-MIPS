_mem m1 10;
_mem m2 20;
_mem m3 30;
_mem m4 40;

_reg r1;
_reg r2;
_reg r3;
_reg r4;
_reg r5;
_reg r6;
_reg r7;
_reg r8;

_func main;

        la      r1, m1;
        lw      r2, 0(r1);

        la      r1, m2;
        lw      r3, 0(r1);

        add     r4, r2, r3;

        la      r1, m3;
        lw      r5, 0(r1);

        sub     r6, r4, r5;

        add     r7, r6, r2;

        bltz    r7, l_neg;
        b       l_pos;

l_neg:
        sub     r8, r2, r3;
        b       end;

l_pos:
        add     r8, r3, r5;

end:
        sw      r8, 0(r1);

        nop;

        jr      r1;